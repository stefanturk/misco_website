# Copy to .env.local (or set in Vercel project settings) — never commit real keys.

# Resend API key (sends RSVP emails). littyd.com must stay verified in Resend
# for the "misco@littyd.com" from-address to work.
RESEND_API_KEY=

# Optional: override the RSVP password. Default accepts "burgershack" (and "bugershack").
RSVP_PASSWORD=burgershack
